# Replace with your DB credentials!
theourban_com_DATABASE_URL="postgres://user:password@host:port/db-name"

# Google AI Studio API key (Gemini)
AISTUDIO_API_KEY=

# Gemini model id for generateContent (default: gemini-3.1-flash-lite-preview)
# AISTUDIO_MODEL=gemini-3.1-flash-lite

# URL slug that `/` redirects to (default: default-landing-page)
# PUBLIC_DEFAULT_SITE_SLUG=default-landing-page
