# Replace with your DB credentials! (Used at runtime by the app.)
theourban_com_DATABASE_URL="postgres://user:password@host:port/db-name"

# Drizzle CLI (migrate / push / studio) and Vercel build-time migrations read, in order:
# POSTGRES_URL_NON_POOLING, POSTGRES_URL, DATABASE_URL, theourban_com_DATABASE_URL
# On Vercel: add the same Postgres URL under Project → Settings → Environment Variables
# for Production (and Preview if previews use a DB). Enable it for "Build" so
# `npm run build:vercel` can run `drizzle-kit migrate` before `vite build`.
# Neon: prefer the direct (non-pooled) connection string for migrations.
# POSTGRES_URL_NON_POOLING=

# Google AI Studio API key (Gemini)
AISTUDIO_API_KEY=

# Gemini model id for generateContent (default: gemini-3.1-flash-lite-preview)
# AISTUDIO_MODEL=gemini-3.1-flash-lite

# URL slug that `/` redirects to (default: default-landing-page)
# PUBLIC_DEFAULT_SITE_SLUG=default-landing-page
